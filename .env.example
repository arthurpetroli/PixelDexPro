# PixelDex Pro - Environment Variables Example
# Copy this file to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pixeldex
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===========================================
# API Configuration
# ===========================================
PROJECT_NAME=PixelDex Pro
VERSION=0.1.0
API_V1_PREFIX=/api/v1

# ===========================================
# PokéAPI Configuration
# ===========================================
POKEAPI_BASE_URL=https://pokeapi.co/api/v2
POKEAPI_REQUEST_TIMEOUT=30
POKEAPI_BATCH_SIZE=50

# ===========================================
# Cobblemon Configuration
# ===========================================
# Google Sheets URL for Cobblemon spawn data
COBBLEMON_SHEET_URL=
# Google Sheets ID (extracted from the URL)
COBBLEMON_SHEET_ID=
# Path to Google service account JSON file (for private sheets)
COBBLEMON_SERVICE_ACCOUNT_FILE=

# ===========================================
# Authentication (Optional - for future use)
# ===========================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===========================================
# Redis Configuration (Optional - for caching)
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# Frontend Configuration
# ===========================================
VITE_API_URL=http://localhost:8000/api/v1
